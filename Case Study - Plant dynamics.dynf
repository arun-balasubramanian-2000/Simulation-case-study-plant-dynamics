  Connect BLOCKS("COL01").Out_B and BLOCKS("PUMP02").In_F with STREAMS("TOL01");
  Connect BLOCKS("PUMP02").Out_P and BLOCKS("VALVE03").In_F with STREAMS("TOL02");
  Connect BLOCKS("VALVE03").Out_P with STREAMS("TOL03");
  Connect BLOCKS("COL01").Stage(1).P via BLOCKS("COL01").OutputSignal4 and BLOCKS("COL01_CondPC").PV via BLOCKS("COL01_CondPC").InputSignal with IS0;
  Connect BLOCKS("COL01_CondPC").OP via BLOCKS("COL01_CondPC").OutputSignal and BLOCKS("COL01").Condenser(1).QR via BLOCKS("COL01").InputSignal with IS1;
  Connect STREAMS("FEED").F via STREAMS("FEED").OutputSignal and B1.PV via B1.InputSignal with S1;
  Connect B1.OP via B1.OutputSignal and BLOCKS("VALVE01").Pos via BLOCKS("VALVE01").InputSignal with S2;
  Connect BLOCKS("COL01").Stage(1).Level via BLOCKS("COL01").OutputSignal and B2.PV via B2.InputSignal with S3;
  Connect B2.OP via B2.OutputSignal and BLOCKS("VALVE02").Pos via BLOCKS("VALVE02").InputSignal with S4;
  Connect BLOCKS("COL01").Stage(40).Level via BLOCKS("COL01").OutputSignal2 and B3.PV via B3.InputSignal with S5;
  Connect B3.OP via B3.OutputSignal and BLOCKS("VALVE03").Pos via BLOCKS("VALVE03").InputSignal with S6;
  Connect BLOCKS("COL01").Stage(34).T via BLOCKS("COL01").OutputSignal3 and B5.PV via B5.InputSignal with S7;
  Connect B5.OP via B5.OutputSignal and BLOCKS("COL01").QRebR via BLOCKS("COL01").InputSignal3 with S8;

